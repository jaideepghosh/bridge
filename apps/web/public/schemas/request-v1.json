{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bridge Request",
  "description": "JSON Schema for Bridge Request exports",
  "type": "object",
  "required": ["type", "name", "method", "url", "headers", "queryParams", "body", "auth"],
  "properties": {
    "$schema": { "type": "string" },
    "type": { "type": "string", "const": "request" },
    "name": { "type": "string" },
    "method": { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS", "HEAD"] },
    "url": { "type": "string" },
    "description": { "type": "string" },
    "operationId": { "type": "string" },
    "headers": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/keyValuePair"
      }
    },
    "queryParams": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/keyValuePair"
      }
    },
    "pathParams": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/keyValuePair"
      }
    },
    "body": {
      "$ref": "#/definitions/requestBody"
    },
    "auth": {
      "$ref": "#/definitions/authConfig"
    }
  },
  "definitions": {
    "keyValuePair": {
      "type": "object",
      "required": ["id", "key", "value", "enabled"],
      "properties": {
        "id": { "type": "string" },
        "key": { "type": "string" },
        "value": { "type": "string" },
        "enabled": { "type": "boolean" }
      }
    },
    "authConfig": {
      "type": "object",
      "required": ["type"],
      "oneOf": [
        {
          "properties": { "type": { "const": "none" } }
        },
        {
          "properties": {
            "type": { "const": "bearer" },
            "token": { "type": "string" }
          },
          "required": ["token"]
        },
        {
          "properties": {
            "type": { "const": "basic" },
            "username": { "type": "string" },
            "password": { "type": "string" }
          },
          "required": ["username", "password"]
        },
        {
          "properties": {
            "type": { "const": "apiKey" },
            "key": { "type": "string" },
            "value": { "type": "string" },
            "in": { "type": "string", "enum": ["header", "query"] }
          },
          "required": ["key", "value", "in"]
        }
      ]
    },
    "requestBody": {
      "type": "object",
      "required": ["type"],
      "oneOf": [
        {
          "properties": { "type": { "const": "none" } }
        },
        {
          "properties": {
            "type": { "const": "json" },
            "content": { "type": "string" }
          },
          "required": ["content"]
        },
        {
          "properties": {
            "type": { "const": "raw" },
            "content": { "type": "string" }
          },
          "required": ["content"]
        },
        {
          "properties": {
            "type": { "const": "form-urlencoded" },
            "pairs": {
              "type": "array",
              "items": { "$ref": "#/definitions/keyValuePair" }
            }
          },
          "required": ["pairs"]
        },
        {
          "properties": {
            "type": { "const": "form-data" },
            "pairs": {
              "type": "array",
              "items": { "$ref": "#/definitions/keyValuePair" }
            }
          },
          "required": ["pairs"]
        }
      ]
    }
  }
}
